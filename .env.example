# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# Legacy projects can use this instead of the publishable key above.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI
OPENAI_API_KEY=
XAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
# Native Automation OS (server/worker only; never expose these via NEXT_PUBLIC_)
CREDENTIAL_ENCRYPTION_KEY=
WEBHOOK_SIGNING_SECRET=
REDIS_URL=
WORKER_CONCURRENCY=4
LOG_LEVEL=info
# Optional social OAuth providers. Keep values server-side.
X_CLIENT_ID=
X_CLIENT_SECRET=
META_APP_ID=
META_APP_SECRET=
CLAUDE_API_KEY=
# Optional. Uses the value configured in lib/copyfast/claude.js when omitted.
CLAUDE_MODEL=

# Admin
ADMIN_EMAILS=alidduvenci@gmail.com

# App URL (Vercel deploy sonrası production domain)
NEXT_PUBLIC_APP_URL=https://app.websitealsat.com

# Telegram AI COO Bot
# Bot token: telegram.md veya @BotFather
TELEGRAM_BOT_TOKEN=
# Sadece bu Telegram kullanıcı ID'si botu kullanabilir (@userinfobot ile öğren)
TELEGRAM_ALLOWED_USER_ID=
# Deep Work görevleri için Supabase auth.users UUID (admin kullanıcı)
TELEGRAM_OWNER_USER_ID=
# Webhook güvenliği (rastgele uzun string)
TELEGRAM_WEBHOOK_SECRET=
# Webhook kurulum endpoint koruması (opsiyonel, TELEGRAM_WEBHOOK_SECRET ile aynı olabilir)
TELEGRAM_SETUP_SECRET=

# Vercel Cron (proaktif öneriler)
CRON_SECRET=

# Webhook kurulumu: deploy sonrası `npm run telegram:setup` veya POST /api/telegram/setup
